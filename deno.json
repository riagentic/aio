{
  "title": "AIO Counter",
  "version": "0.3.0",
  "unstable": ["kv"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "@types/react"
  },
  "imports": {
    "@types/react": "npm:@types/react@^18",
    "react": "npm:react@^18",
    "react-dom": "npm:react-dom@^18",
    "aio": "./dep/aio/mod.ts",
    "esbuild": "npm:esbuild@^0.24",
    "immer": "npm:immer@^10",
    "@std/path": "jsr:@std/path@^1"
  },
  "tasks": {
    "test": "deno test -A --unstable-kv dep/aio/tests/",
    "check": "deno check dep/aio/mod.ts",
    "dev": "deno run -A src/app.ts",
    "compile": "deno run -A dep/aio/src/build.ts --compile",
    "compile:browser": "deno run -A dep/aio/src/build.ts --compile",
    "compile:browser:remote": "deno run -A dep/aio/src/build.ts --compile --service --remote",
    "compile:electron": "deno run -A dep/aio/src/build.ts --compile --electron",
    "compile:electron:remote": "deno run -A dep/aio/src/build.ts --client",
    "compile:cli": "deno run -A dep/aio/src/build.ts --cli",
    "compile:cli:remote": "deno run -A dep/aio/src/build.ts --cli --remote",
    "compile:android": "deno run -A dep/aio/src/build.ts --android",
    "compile:android:remote": "deno run -A dep/aio/src/build.ts --android --remote",
    "compile:service": "deno run -A dep/aio/src/build.ts --compile --service --headless",
    "compile:service:remote": "deno run -A dep/aio/src/build.ts --compile --service --headless --remote",
    "am": "deno run -A dep/aio/src/am.ts"
  }
}
